# Frontend Environment Variables
# Dev: ชี้ไปที่ backend (พอร์ตให้ตรงกับที่รันจริง)
VITE_API_URL=http://localhost:3001
# Production แยกโดเมน (SPA คนละ host กับ API): VITE_SINGLE_HOST_API=false แล้วตั้ง VITE_API_URL
# VITE_SAME_ORIGIN_API=true — ทางเลือกสำรอง (ถ้าไม่ใช้สคริปต์ใน index จาก vite build)
VITE_SINGLE_HOST_API=
VITE_SAME_ORIGIN_API=
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
