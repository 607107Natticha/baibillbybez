# Frontend Environment Variables
# Dev: ชี้ไปที่ backend (พอร์ตให้ตรงกับที่รันจริง)
VITE_API_URL=http://localhost:3001
# Production โฮสต์เดียว: ไม่ต้องตั้ง VITE_API_URL — หรือถ้ามี VITE_API_URL เก่าค้างใน build ให้ตั้ง VITE_SAME_ORIGIN_API=true เพื่อบังคับใช้ origin เดียวกับหน้าเว็บ
# Production แยกโดเมน: ตั้ง VITE_API_URL=https://api.example.com (อย่าใส่ VITE_SAME_ORIGIN_API) + ตั้ง FRONTEND_URL บน backend
VITE_SAME_ORIGIN_API=
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
