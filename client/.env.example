# Frontend Environment Variables
# Dev: ชี้ไปที่ backend (พอร์ตให้ตรงกับที่รันจริง)
VITE_API_URL=http://localhost:3001
# Production build: ตั้งเป็น URL สาธารณะเดียวกับที่ผู้ใช้เปิดแอป (หรือใช้ client/.env.production / env บน PaaS)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
