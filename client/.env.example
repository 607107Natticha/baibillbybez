# Frontend Environment Variables
# Dev: ชี้ไปที่ backend (พอร์ตให้ตรงกับที่รันจริง)
VITE_API_URL=http://localhost:3001
# Production โฮสต์เดียว: ไม่ต้องตั้ง VITE_API_URL — client ใช้ origin เดียวกับหน้าเว็บอัตโนมัติ
# แยกโดเมน: VITE_SINGLE_HOST_API=false แล้วตั้ง VITE_API_URL + FRONTEND_URL บน API
# VITE_SAME_ORIGIN_API=true — บังคับ same-origin แม้มี VITE_API_URL (กรณีพิเศษ)
VITE_SINGLE_HOST_API=
VITE_SAME_ORIGIN_API=
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
