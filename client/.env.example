# Frontend Environment Variables
# Dev: ชี้ไปที่ backend (พอร์ตให้ตรงกับที่รันจริง)
VITE_API_URL=http://localhost:3001
# Production โฮสต์เดียว (Express serve SPA + /api): ไม่ต้องตั้ง VITE_API_URL ตอน build — แอปจะใช้ origin เดียวกับหน้าเว็บ
# Production แยกโดเมน: ตั้ง VITE_API_URL=https://api.example.com และบน backend ตั้ง FRONTEND_URL หรือ CORS_ALLOWED_ORIGINS ให้ตรงโดเมนหน้าเว็บ
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
